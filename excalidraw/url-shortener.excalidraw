      "link": null,
      "locked": false,
      "text": "Core entities:\n    - User\n    - ShortUrl\n    - LongUrl",
      "fontSize": 20.31117676151576,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Core entities:\n    - User\n    - ShortUrl\n    - LongUrl",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "jUhObsRW5d9DC7T3klEJ9",
      "type": "text",
      "x": 14944.365722869736,
      "y": 1042.5228153146188,
      "width": 476.01232917332976,
      "height": 355.4455933265258,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0X",
      "roundness": null,
      "seed": 156760449,
      "version": 597,
      "versionNonce": 1007635713,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779282322546,
      "link": null,
      "locked": false,
      "text": "API:\n   - user should be able to get short url by long url\n    POST /api/v1/urls  -> shortUrl\n    HEADERS: userId | token\n    {\n        longUrl\n        alias?\n        expirationTime?\n    }\n\n    - user should be able to be redirected by short url\n    GET  {shortUrl} -> redirect to longUrl (301, 302)\n    HEADERS: userId | token\n",
      "fontSize": 20.31117676151576,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "API:\n   - user should be able to get short url by long url\n    POST /api/v1/urls  -> shortUrl\n    HEADERS: userId | token\n    {\n        longUrl\n        alias?\n        expirationTime?\n    }\n\n    - user should be able to be redirected by short url\n    GET  {shortUrl} -> redirect to longUrl (301, 302)\n    HEADERS: userId | token\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
