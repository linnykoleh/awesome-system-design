    {
      "id": "OiKL7YVp2L4lx2KdsHyR0",
      "type": "text",
      "x": 14941.004378581345,
      "y": 339.7771062877984,
      "width": 476.01232917332976,
      "height": 76.1669128556841,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0T",
      "roundness": null,
      "seed": 717266255,
      "version": 405,
      "versionNonce": 1806056801,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779282322546,
      "link": null,
      "locked": false,
      "text": "Functional requirements:\n    - user should be able to get short url by long url\n    - user should be able to be redirected by short url",
      "fontSize": 20.31117676151576,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Functional requirements:\n    - user should be able to get short url by long url\n    - user should be able to be redirected by short url",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "YxceuxkQCHAndLfZtqX3K",
      "type": "text",
      "x": 14937.276540910407,
      "y": 602.9092158301246,
      "width": 537.5753925053141,
      "height": 203.1117676151576,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0U",
      "roundness": null,
      "seed": 1401105999,
      "version": 705,
      "versionNonce": 362408257,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779282322546,
      "link": null,
      "locked": false,
      "text": "Non functional requirements:\n    - system should be low latency on redirection <= 200ms\n    - highly availability >> strong consistency\n    - 100M dau\n    - 1B users overall\n    - ensure uniquiness for shortUrls\n    - 100:1 read to write ratio\n    - durable not to lose urls",
      "fontSize": 20.31117676151576,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Non functional requirements:\n    - system should be low latency on redirection <= 200ms\n    - highly availability >> strong consistency\n    - 100M dau\n    - 1B users overall\n    - ensure uniquiness for shortUrls\n    - 100:1 read to write ratio\n    - durable not to lose urls",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "RevEP7VEOgPtP9dL0UH5r",
      "type": "text",
      "x": 14951.043934491341,
      "y": 861.3236700250463,
      "width": 120.14051291831775,
      "height": 101.5558838075788,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
