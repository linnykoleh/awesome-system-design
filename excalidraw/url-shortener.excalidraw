    {
      "id": "UUQjk5-tWz4R8lawmq25C",
      "type": "text",
      "x": 16424.880154966075,
      "y": 1122.1454651444856,
      "width": 477.21495000418906,
      "height": 437.10180401460275,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#d0bfff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b10",
      "roundness": null,
      "seed": 1115013967,
      "version": 870,
      "versionNonce": 256753999,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779282841296,
      "link": null,
      "locked": false,
      "text": "Solution to uniquiness:\n     ❌ 1. prefix of long ulr\n            - additional read db if collision\n     ❌ 2. random generation - 6 chars\n            - base62 encoding- 62^6 = 56B url\n            - additional read db if collision\n     ❌ 3. hash long url\n             - hashCode(url)\n             - additional read db if collision\n      ✅ 4. global counter\n                - Redis single threaded\n                - use Redis with INRC\n                - base62 endoing\n                - predictability bad for security",
      "fontSize": 24.977245943691564,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Solution to uniquiness:\n     ❌ 1. prefix of long ulr\n            - additional read db if collision\n     ❌ 2. random generation - 6 chars\n            - base62 encoding- 62^6 = 56B url\n            - additional read db if collision\n     ❌ 3. hash long url\n             - hashCode(url)\n             - additional read db if collision\n      ✅ 4. global counter\n                - Redis single threaded\n                - use Redis with INRC\n                - base62 endoing\n                - predictability bad for security",
      "autoResize": true,
      "lineHeight": 1.25
    },
