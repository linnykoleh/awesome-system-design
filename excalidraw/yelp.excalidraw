      "isDeleted": false,
      "boundElements": null,
      "updated": 1780046508333,
      "link": null,
      "locked": false,
      "text": "Functional requirements:\n    - user should be able search for businesses (location, name, category)\n    - view business and their reviews\n    - leave the reviews (1-5 star + optional text)",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Functional requirements:\n    - user should be able search for businesses (location, name, category)\n    - view business and their reviews\n    - leave the reviews (1-5 star + optional text)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "PRKOG-tKyP2FC2ZV6D9yj",
      "type": "text",
      "x": 22857.734658856654,
      "y": 1697.9876692002672,
      "width": 180.2397918701172,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#da77f2",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b63",
      "roundness": null,
      "seed": 868481699,
      "version": 78,
      "versionNonce": 1379851523,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1780046510116,
      "link": null,
      "locked": false,
      "text": "Scale:\n    - 10M businesses\n    - 10M DAU",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Scale:\n    - 10M businesses\n    - 10M DAU",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "AQbkKmdc2tgyAL_H9uCje",
      "type": "text",
      "x": 22850.301304176395,
      "y": 1870.458179468753,
      "width": 553.3392944335938,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#da77f2",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b64",
      "roundness": null,
      "seed": 403415299,
      "version": 253,
      "versionNonce": 1069850435,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1780046511368,
      "link": null,
      "locked": false,
      "text": "Non functional requirements:\n    - availability >> consistency\n    - low latency on search (~500ms)\n    - system should be able to scale to handle 10M businesses\n    - system should be able to scale to handle 10M DAU\n    ",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Non functional requirements:\n    - availability >> consistency\n    - low latency on search (~500ms)\n    - system should be able to scale to handle 10M businesses\n    - system should be able to scale to handle 10M DAU\n    ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "C_DWh_5qVfWmqNXbtOjtK",
      "type": "text",
      "x": 22860.254912269374,
      "y": 2080.406614182515,
      "width": 314.4395751953125,
      "height": 50,
