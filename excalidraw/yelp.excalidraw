      "locked": false,
      "text": "Core entities:\n    - Business\n    - User\n    - Review\n    ",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Core entities:\n    - Business\n    - User\n    - Review\n    ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "PnJxhco3wiljsAmIcGDE8",
      "type": "text",
      "x": 22847.83708365646,
      "y": 2412.2984599014944,
      "width": 836.7190551757812,
      "height": 575,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#da77f2",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b67",
      "roundness": null,
      "seed": 1561057357,
      "version": 505,
      "versionNonce": 2039468547,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1780046514070,
      "link": null,
      "locked": false,
      "text": "API:\n    - user should be able search for businesses (location, name, category)\n    GET /api/v1/businesses?query={}&location={}&category={}&page={}&size={} -> Business[]\n\n\n    - view business and their reviews\n    GET /api/v1/businesses/{businessId} -> Business 200 | 404\n    \n    GET /api/v1/businesses/{businessId}/reviews?page={}&size={}  -> Review[]\n\n\n    - leave the reviews (1-5 star + optional text)\n    POST /api/v1/reviews/{businessId} -> Review 200\n    Headers: JWT\n    Body: {\n        rating,\n        text?\n    }\n        \n    \n\n    \n",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "API:\n    - user should be able search for businesses (location, name, category)\n    GET /api/v1/businesses?query={}&location={}&category={}&page={}&size={} -> Business[]\n\n\n    - view business and their reviews\n    GET /api/v1/businesses/{businessId} -> Business 200 | 404\n    \n    GET /api/v1/businesses/{businessId}/reviews?page={}&size={}  -> Review[]\n\n\n    - leave the reviews (1-5 star + optional text)\n    POST /api/v1/reviews/{businessId} -> Review 200\n    Headers: JWT\n    Body: {\n        rating,\n        text?\n    }\n        \n    \n\n    \n",
      "autoResize": true,
      "lineHeight": 1.25
    },
