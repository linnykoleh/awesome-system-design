      "locked": false,
      "text": "Constaint\n    - 1 review per user, per business",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Constaint\n    - 1 review per user, per business",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
