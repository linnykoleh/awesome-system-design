      "seed": 1352552040,
      "version": 254,
      "versionNonce": 241149720,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779718865239,
      "link": null,
      "locked": false,
      "text": "Functional requirements:\n    - users should be able to create/schedule a job (immediate, future,  recoccuring)\n    - users should be able to monitor the status of the jobs",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Functional requirements:\n    - users should be able to create/schedule a job (immediate, future,  recoccuring)\n    - users should be able to monitor the status of the jobs",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "D0WwmhvNiyctnxjmHGro6",
      "type": "text",
      "x": 11496.573136964842,
      "y": -344.24357559636337,
      "width": 338.43963623046875,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b5E",
      "roundness": null,
      "seed": 1987405672,
      "version": 170,
      "versionNonce": 1671362408,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779717901275,
      "link": null,
      "locked": false,
      "text": "Task: SendEmail\nJob: Sending an email to John at noon",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Task: SendEmail\nJob: Sending an email to John at noon",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "cCwWcV6mANNh_W-eR2dNV",
      "type": "text",
      "x": 11499.303605714842,
      "y": -146.48185684636337,
      "width": 304.879638671875,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b5F",
      "roundness": null,
      "seed": 1060898840,
      "version": 113,
      "versionNonce": 245090920,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779717901275,
      "link": null,
      "locked": false,
      "text": "Scale:\n    - 10K jobs per second executed",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Scale:\n    - 10K jobs per second executed",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "MGNjFo7KalCJDpmE9fk2T",
      "type": "text",
      "x": 11502.850480714842,
      "y": -71.53654434636337,
      "width": 541.4593505859375,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b5H",
      "roundness": null,
      "seed": 1206506088,
      "version": 368,
      "versionNonce": 143015272,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779717901275,
      "link": null,
      "locked": false,
      "text": "Non functional requirements:\n    - cap theorem - availability >> consistency on job creation\n        - every read will not see the latest write\n    - low latency on job execution (2 s)\n    - scalabale to 10k/sec jobs\n    - at-least-once execution",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Non functional requirements:\n    - cap theorem - availability >> consistency on job creation\n        - every read will not see the latest write\n    - low latency on job execution (2 s)\n    - scalabale to 10k/sec jobs\n    - at-least-once execution",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "MwjG4MBCSLh2RQspnrJ1s",
      "type": "text",
      "x": 11510.436418214842,
      "y": 96.84626815363663,
      "width": 118.29988098144531,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
