    {
      "id": "2OOs0vLR4LQEm-0gA4H6C",
      "type": "text",
      "x": 18676.188100178653,
      "y": 91.80795824355471,
      "width": 1126.943359375,
      "height": 280,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
