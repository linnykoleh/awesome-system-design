      "isDeleted": false,
      "boundElements": null,
      "updated": 1779966095308,
      "link": null,
      "locked": false,
      "text": "API:\n    - users should be able to view an aggregated feed of news articles \n    GET /api/v1/feed?page={page}&limit={limit}&region={region} -> Article[]\n    HEADERS: JWT\n    ",
      "fontSize": 25.63116332949155,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "API:\n    - users should be able to view an aggregated feed of news articles \n    GET /api/v1/feed?page={page}&limit={limit}&region={region} -> Article[]\n    HEADERS: JWT\n    ",
      "autoResize": true,
      "lineHeight": 1.25
    },
