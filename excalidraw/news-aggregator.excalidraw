  "elements": [
    {
      "id": "MzW9_zpDgz_JavjsbtFw_",
      "type": "text",
      "x": 17504.876182364733,
      "y": 789.2462951925535,
      "width": 1437.0347006749064,
      "height": 128.15581664745775,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b48",
      "roundness": null,
      "seed": 676754458,
      "version": 246,
      "versionNonce": 1203877510,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779966095308,
      "link": null,
      "locked": false,
      "text": "Functional requirements:\n    - users should be able to view an aggregated feed of news articles from thousands of source publishers all over the world\n    - users should be able to scroll through the feed \"infinitely\"\n    - users should be able to click on articles and be redirected to the publisher's website to read the full content",
      "fontSize": 25.63116332949155,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Functional requirements:\n    - users should be able to view an aggregated feed of news articles from thousands of source publishers all over the world\n    - users should be able to scroll through the feed \"infinitely\"\n    - users should be able to click on articles and be redirected to the publisher's website to read the full content",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "MMuV8lvLxAv1ip2fObRMl",
      "type": "text",
      "x": 17505.450323342087,
      "y": 1014.8005503856217,
      "width": 780.1602668568391,
      "height": 128.15581664745775,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b49",
      "roundness": null,
      "seed": 1818565510,
      "version": 224,
      "versionNonce": 1150612934,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779966095308,
      "link": null,
      "locked": false,
      "text": "Out of scope:\n    - users should be able to customize their feed based on interests\n    - users should be able to save articles for later reading\n    - users should be able to share articles on social media platforms",
      "fontSize": 25.63116332949155,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Out of scope:\n    - users should be able to customize their feed based on interests\n    - users should be able to save articles for later reading\n    - users should be able to share articles on social media platforms",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "-V-5o00UbGnSuZECQnT3o",
      "type": "text",
      "x": 17509.311537351725,
      "y": 1271.571282026283,
      "width": 1151.0683401756648,
      "height": 128.15581664745775,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4A",
      "roundness": null,
      "seed": 2114133210,
      "version": 256,
      "versionNonce": 457067782,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779966095308,
      "link": null,
      "locked": false,
      "text": "Non functional requirements:\n    - system should prioritize availability over consistency (CAP theorem)\n    - system should be scalable to handle 100 million daily active users with spikes up to 500 million\n    - system should have low latency feed load times (< 200ms)",
      "fontSize": 25.63116332949155,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Non functional requirements:\n    - system should prioritize availability over consistency (CAP theorem)\n    - system should be scalable to handle 100 million daily active users with spikes up to 500 million\n    - system should have low latency feed load times (< 200ms)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "VTT-2LpK-GMEV7NI7c9Gq",
      "type": "text",
      "x": 17515.29441159398,
      "y": 1499.98125122576,
      "width": 153.94054559403494,
      "height": 128.15581664745775,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
