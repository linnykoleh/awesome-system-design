    {
      "id": "RzvhjK8AznLEOFi4_mhrV",
      "type": "text",
      "x": 10500.890353470128,
      "y": -1489.5172740144144,
      "width": 626.8991088867188,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#7950f2",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3F",
      "roundness": null,
      "seed": 275248744,
      "version": 786,
      "versionNonce": 912238104,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779620710806,
      "link": null,
      "locked": false,
      "text": "✅ High-load precomputed feed generation (fanout on write):\n    1. Every user have a feed cache\n    2. When a user creates a post, we get all followers who follow him\n    3. Then add that post to a their precomputed feed cache \n    4. On reading a feed add celebrities posts to feed on fly",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "✅ High-load precomputed feed generation (fanout on write):\n    1. Every user have a feed cache\n    2. When a user creates a post, we get all followers who follow him\n    3. Then add that post to a their precomputed feed cache \n    4. On reading a feed add celebrities posts to feed on fly",
      "autoResize": true,
      "lineHeight": 1.25
    },
