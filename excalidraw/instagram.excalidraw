      "seed": 1663626509,
      "version": 550,
      "versionNonce": 1329636456,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1779620816002,
      "link": null,
      "locked": false,
      "text": "Functional requirements:\n    - create posts with photos/videos and caption\n    - follow other users\n    - see a chronological feed of posts from users they follow",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Functional requirements:\n    - create posts with photos/videos and caption\n    - follow other users\n    - see a chronological feed of posts from users they follow",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "LkJLkNj0zMcznEQRz-OnO",
      "type": "text",
      "x": 8682.630034900052,
      "y": -1103.9344315098565,
      "width": 419.47943115234375,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a18072",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2V",
      "roundness": null,
      "seed": 1467364621,
      "version": 691,
      "versionNonce": 1400887144,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1779620816002,
      "link": null,
      "locked": false,
      "text": "Non functional requirements:\n    - scalable to 500M DAU\n    - avalability >> consistency for post creation\n    - low latency feed loading (< 500ms)\n    - low latency media delivery (<500ms)",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Non functional requirements:\n    - scalable to 500M DAU\n    - avalability >> consistency for post creation\n    - low latency feed loading (< 500ms)\n    - low latency media delivery (<500ms)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "xO09RQJX7kVo4rBAh2uwP",
