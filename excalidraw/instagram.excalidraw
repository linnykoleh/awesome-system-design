    {
      "id": "6GRivQcIjvnL_M89QyThj",
      "type": "text",
      "x": 8686.975829812309,
      "y": -891.8975228135948,
      "width": 223.9997100830078,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a18072",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2X",
      "roundness": null,
      "seed": 319123885,
      "version": 505,
      "versionNonce": 1571757416,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1779620816002,
      "link": null,
      "locked": false,
      "text": "Core entities:\n    - User\n    - Post\n    - Media (photo/videos)\n    - Follow\n    - Feed",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Core entities:\n    - User\n    - Post\n    - Media (photo/videos)\n    - Follow\n    - Feed",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "3to_v0XxGdC8KvSe_S9TS",
      "type": "text",
      "x": 8678.775484734586,
      "y": -671.6348297224424,
      "width": 539.5392456054688,
      "height": 625,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a18072",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2Y",
      "roundness": null,
      "seed": 1394754339,
      "version": 840,
      "versionNonce": 1723722520,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1779620857966,
      "link": null,
      "locked": false,
      "text": "API:\n    - create posts with photos/videos and caption\n    POST /api/v1/posts -> {postId,  upload_url} (200)\n    Header: JWT | token\n    body : {\n        description\n    }\n\n    PUT /{upload_media_url}\n    Header: JWT | token\n    body: {\n        byte{]\n    }\n\n    - follow other users\n    POST /api/v1/follow -> 200\n    Header: JWT | token\n    body : {\n        followedId\n    }\n\n    - see a chronological feed of posts from users they follow\n    GET /api/v1/feeds?size&page ->  Feed\n    Header: JWT | token\n    ",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "API:\n    - create posts with photos/videos and caption\n    POST /api/v1/posts -> {postId,  upload_url} (200)\n    Header: JWT | token\n    body : {\n        description\n    }\n\n    PUT /{upload_media_url}\n    Header: JWT | token\n    body: {\n        byte{]\n    }\n\n    - follow other users\n    POST /api/v1/follow -> 200\n    Header: JWT | token\n    body : {\n        followedId\n    }\n\n    - see a chronological feed of posts from users they follow\n    GET /api/v1/feeds?size&page ->  Feed\n    Header: JWT | token\n    ",
      "autoResize": true,
      "lineHeight": 1.25
    },
