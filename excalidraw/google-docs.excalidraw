      "boundElements": null,
      "updated": 1779561012368,
      "link": null,
      "locked": false,
      "text": "Core entities:\n    - Document\n    - User\n    - Edit\n    - Cursor",
      "fontSize": 26.584454948650695,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Core entities:\n    - Document\n    - User\n    - Edit\n    - Cursor",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "zTX4ka57JR31yh-xaKnOY",
      "type": "text",
      "x": 6968.395139561086,
      "y": -1262.8505948170957,
      "width": 823.0137210401766,
      "height": 963.6864918885877,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1D",
      "roundness": null,
      "seed": 770252781,
      "version": 1445,
      "versionNonce": 300391181,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779561012368,
      "link": null,
      "locked": false,
      "text": "API (should satisfy functional requirements):\n    - users should be able to create new documents\n    POST /api/v1/docs  - > { docId }\n    Header: JWT | userToken | sessionToken\n    body {\n           title\n    }\n\n    - users should be able to edit the documents\n    WS /docs/{docId}\n        SEND {\n            type: \"insert\" | \"delete\"\n            ...\n         }\n\n    - users should be able concurrently view/edit documents\n    WS /docs/{docId}\n        RECV: {\n            type: \"update\"\n            ...\n        }\n\n    - users should be able to view the cursor or position of other users\n   WS /docs/{docId}\n        SEND {\n            type: \"insert\" | \"delete\"\n            ...\n         }\n        ",
      "fontSize": 26.584454948650695,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "API (should satisfy functional requirements):\n    - users should be able to create new documents\n    POST /api/v1/docs  - > { docId }\n    Header: JWT | userToken | sessionToken\n    body {\n           title\n    }\n\n    - users should be able to edit the documents\n    WS /docs/{docId}\n        SEND {\n            type: \"insert\" | \"delete\"\n            ...\n         }\n\n    - users should be able concurrently view/edit documents\n    WS /docs/{docId}\n        RECV: {\n            type: \"update\"\n            ...\n        }\n\n    - users should be able to view the cursor or position of other users\n   WS /docs/{docId}\n        SEND {\n            type: \"insert\" | \"delete\"\n            ...\n         }\n        ",
      "autoResize": true,
      "lineHeight": 1.25
    },
