      "seed": 676442573,
      "version": 1177,
      "versionNonce": 1744080877,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779561012368,
      "link": null,
      "locked": false,
      "text": "Functional requirements:\n    - users should be able to create new documents\n    - users should be able to edit the documents\n    - users should be able concurrently view/edit documents\n    - users should be able to view the cursor or position of other users",
      "fontSize": 26.584454948650695,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Functional requirements:\n    - users should be able to create new documents\n    - users should be able to edit the documents\n    - users should be able concurrently view/edit documents\n    - users should be able to view the cursor or position of other users",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "qrk8HBLcYOJjv0i77V3qQ",
      "type": "text",
      "x": 6983.439811666551,
      "y": -1788.6319604666053,
      "width": 692.7101885162105,
      "height": 265.84454948650693,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1B",
      "roundness": null,
      "seed": 383706637,
      "version": 1257,
      "versionNonce": 1276512845,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779561012368,
      "link": null,
      "locked": false,
      "text": "Non functional requirements:\n    - availability >> consistency\n        - strong consistency - every read returns latest write \n    - durable documents\n    - low latency on updates ( < 100ms)\n    - 100M users DAU\n    - 100 editors per document\n    - eventual consistency of edits",
      "fontSize": 26.58445494865069,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Non functional requirements:\n    - availability >> consistency\n        - strong consistency - every read returns latest write \n    - durable documents\n    - low latency on updates ( < 100ms)\n    - 100M users DAU\n    - 100 editors per document\n    - eventual consistency of edits",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "MPjs_tSFJoUnpikBCjdS4",
      "type": "text",
      "x": 6988.278941776411,
      "y": -1483.6711321187101,
      "width": 169.98078832639325,
      "height": 166.15284342906685,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "dashed",
