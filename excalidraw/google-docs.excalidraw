      "y": -2000.8910177736113,
      "width": 823.0137210401766,
      "height": 166.15284342906682,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 1,
