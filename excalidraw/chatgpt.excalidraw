      "isDeleted": false,
      "boundElements": null,
      "updated": 1779700817295,
      "link": null,
      "locked": false,
      "text": "Core entities:\n    - User\n    - Chat \n    - Message",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Core entities:\n    - User\n    - Chat \n    - Message",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "k3T3-mynMtgAJdiVKkyrB",
      "type": "text",
      "x": 10101.484279280085,
      "y": -207.7096440543928,
      "width": 796.558837890625,
      "height": 500,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4E",
      "roundness": null,
      "seed": 269724008,
      "version": 448,
      "versionNonce": 823833960,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779700817295,
      "link": null,
      "locked": false,
      "text": "API:\n    - user should be able to starts a new chat\n    POST /api/v1/chats -> chatId\n    Header: JWT\n\n    - users should be able to send a prompt in chat and receive a AI-generated responce\n    POST /api/v1/chats/{chatId}/messages -> Message (streamed via SSE)\n    Header: JWT\n    Body: {\n        content\n    }\n\n    - user should be able to view past chats and resume a converstation with chat context\n    GET /api/v1/chats?page&size -> Chat[]\n    Header: JWT\n\n    GET /api/v1/chats/{chatId}/messages?page&size -> Messages[]\n    Header: JWT\n\n",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "API:\n    - user should be able to starts a new chat\n    POST /api/v1/chats -> chatId\n    Header: JWT\n\n    - users should be able to send a prompt in chat and receive a AI-generated responce\n    POST /api/v1/chats/{chatId}/messages -> Message (streamed via SSE)\n    Header: JWT\n    Body: {\n        content\n    }\n\n    - user should be able to view past chats and resume a converstation with chat context\n    GET /api/v1/chats?page&size -> Chat[]\n    Header: JWT\n\n    GET /api/v1/chats/{chatId}/messages?page&size -> Messages[]\n    Header: JWT\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
