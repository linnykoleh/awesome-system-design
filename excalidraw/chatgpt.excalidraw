    {
      "id": "FK8vc3bjq7BUbmM4phMLI",
      "type": "text",
      "x": 11780.664574679997,
      "y": 141.80826524722238,
      "width": 1492.177734375,
      "height": 200,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "#eebefa",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4o",
      "roundness": null,
      "seed": 388046104,
      "version": 670,
      "versionNonce": 900258584,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779701796608,
      "link": null,
      "locked": false,
      "text": "Full flow on a send:\n1. Chat Service persists the user's message runId, returning it to the client right away.\n2. Chat Service hands the assembled prompt and that runId off to the Inference Service via Queue\n3. User opens an SSE connection for that runId, and the load balancer routes it to any Chat Service instance.\n4. Chat Service instance starts a blocking XREAD on the runId stream, from the beginning for a fresh connection or from the client's last-seen entry ID on a reconnect.\n5. Inference service generates tokens and XADDs each one to the runId stream.\n6. Chat Service instance reads new entries, forwards them down the SSE connection, and the browser appends them. \n7. If the connection drops, the browser reconnects, lands on some Chat Service instance, and that instance replays from the last-seen ID before continuing live.",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Full flow on a send:\n1. Chat Service persists the user's message runId, returning it to the client right away.\n2. Chat Service hands the assembled prompt and that runId off to the Inference Service via Queue\n3. User opens an SSE connection for that runId, and the load balancer routes it to any Chat Service instance.\n4. Chat Service instance starts a blocking XREAD on the runId stream, from the beginning for a fresh connection or from the client's last-seen entry ID on a reconnect.\n5. Inference service generates tokens and XADDs each one to the runId stream.\n6. Chat Service instance reads new entries, forwards them down the SSE connection, and the browser appends them. \n7. If the connection drops, the browser reconnects, lands on some Chat Service instance, and that instance replays from the last-seen ID before continuing live.",
      "autoResize": true,
      "lineHeight": 1.25
    },
