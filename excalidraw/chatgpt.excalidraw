    {
      "id": "evvsAhZ8Crtg-_iQDfgSx",
      "type": "text",
      "x": 10071.640529280085,
      "y": -721.7018315543928,
      "width": 796.558837890625,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4B",
      "roundness": null,
      "seed": 620764184,
      "version": 400,
      "versionNonce": 344276072,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779700817295,
      "link": null,
      "locked": false,
      "text": "Functional requirements:\n    - user should be able to starts a new chat\n    - users should be able to send a prompt in chat and receive a AI-generated responce\n    - user should be able to view past chats and resume a converstation with chat context",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Functional requirements:\n    - user should be able to starts a new chat\n    - users should be able to send a prompt in chat and receive a AI-generated responce\n    - user should be able to view past chats and resume a converstation with chat context",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "kBz8EEzzRWmk_mlcUs4N8",
      "type": "text",
      "x": 10079.554591780085,
      "y": -574.1198003043928,
      "width": 739.0588989257812,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4C",
      "roundness": null,
      "seed": 1385612568,
      "version": 407,
      "versionNonce": 879849320,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779700817295,
      "link": null,
      "locked": false,
      "text": "Non functional requirements:\n    - low latency on responce (~500ms)\n    - full responce can take up to 30sec to finish\n    - system should prioritize high availability over strong consistency for chat state\n    - 200M DAU\n    - 20K promts/sec at peak",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Non functional requirements:\n    - low latency on responce (~500ms)\n    - full responce can take up to 30sec to finish\n    - system should prioritize high availability over strong consistency for chat state\n    - 200M DAU\n    - 20K promts/sec at peak",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "tb7uNMmoXQ9THXd96d1Ze",
      "type": "text",
      "x": 10089.761623030085,
      "y": -366.7096440543928,
      "width": 118.29988098144531,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
