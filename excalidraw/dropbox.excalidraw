      "link": null,
      "locked": false,
      "text": "Core entities:\n    - File (raw bytes)\n    - FileMetadata\n    - User",
      "fontSize": 22.362110717187058,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Core entities:\n    - File (raw bytes)\n    - FileMetadata\n    - User",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "hCFGUhVk2HB9vzvQ5gXaw",
      "type": "text",
      "x": 15814.807283744425,
      "y": 1261.7945949493185,
      "width": 607.6997680664062,
      "height": 642.9106831191278,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a18072",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1I",
      "roundness": null,
      "seed": 1771494287,
      "version": 439,
      "versionNonce": 1586434991,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779348674346,
      "link": null,
      "locked": false,
      "text": "API:\n    - upload file for remote storage\n    POST /api/v1/files  -> FileMetadata\n    HEADERS: JWT | token\n    {\n        name\n        size\n        chunk\n    }\n    \n    PUT {pre_signed_url}\n    {\n        byte[]\n    }\n\n    - download file from remote storage\n    GET /api/v1/{file_id}\n    HEADERS: JWT | token\n\n    - automaticaly sync files across devices\n    GET /api/v1/changes?since={timestamp} -> FIleMetadata[]\n    HEADERS: JWT | token\n",
      "fontSize": 22.362110717187058,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "API:\n    - upload file for remote storage\n    POST /api/v1/files  -> FileMetadata\n    HEADERS: JWT | token\n    {\n        name\n        size\n        chunk\n    }\n    \n    PUT {pre_signed_url}\n    {\n        byte[]\n    }\n\n    - download file from remote storage\n    GET /api/v1/{file_id}\n    HEADERS: JWT | token\n\n    - automaticaly sync files across devices\n    GET /api/v1/changes?since={timestamp} -> FIleMetadata[]\n    HEADERS: JWT | token\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
