    {
      "id": "yIvIPSuIWk4667FTEAOoO",
      "type": "text",
      "x": 15787.087667068767,
      "y": 763.0499587049583,
      "width": 543.3251953125,
      "height": 195.66846877538674,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a18072",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1G",
      "roundness": null,
      "seed": 1436883183,
      "version": 410,
      "versionNonce": 1046036321,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779348665057,
      "link": null,
      "locked": false,
      "text": "Non functional requirements:\n    - highly availability >> strong consistency\n        - after upload file, downloaded file could be stale\n    - low latency upload/download \n    - support large files up to 50Gb\n        - resumable upload\n    - high data integrity (sync accuracy)",
      "fontSize": 22.362110717187058,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Non functional requirements:\n    - highly availability >> strong consistency\n        - after upload file, downloaded file could be stale\n    - low latency upload/download \n    - support large files up to 50Gb\n        - resumable upload\n    - high data integrity (sync accuracy)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "88Ew3NydtiUG_1B_Towuv",
      "type": "text",
      "x": 15799.357466959602,
      "y": 1035.8836549146622,
      "width": 195.8246957711122,
      "height": 111.81055358593528,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a18072",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1H",
