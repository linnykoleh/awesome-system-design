      "boundElements": null,
      "updated": 1779348639757,
      "link": null,
      "locked": false,
      "text": "Functional requirements:\n    - upload file for remote storage\n    - download file from remote storage\n    - automaticaly sync files across devices",
      "fontSize": 22.362110717187058,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Functional requirements:\n    - upload file for remote storage\n    - download file from remote storage\n    - automaticaly sync files across devices",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "D8oHrqv-fQNSwS2GrbN85",
      "type": "text",
      "x": 15781.872752967922,
      "y": 621.77797511995,
      "width": 344.0853431020083,
      "height": 55.90527679296764,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a18072",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
