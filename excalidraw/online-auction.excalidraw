      "boundElements": null,
      "updated": 1780053059103,
      "link": null,
      "locked": false,
      "text": "Core entities:\n    - User\n    - Auction\n    - Item\n    - Bid    ",
      "fontSize": 24.881376312440214,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Core entities:\n    - User\n    - Auction\n    - Item\n    - Bid    ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "GfhZbbxEtAjxmJzh5jfvL",
      "type": "text",
      "x": 24013.540543909177,
      "y": 2855.128762677183,
      "width": 722.5542417436621,
      "height": 901.9498913259577,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#9775fa",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b6u",
      "roundness": null,
      "seed": 846697069,
      "version": 670,
      "versionNonce": 396283437,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1780053059103,
      "link": null,
      "locked": false,
      "text": "API:\n   - users should be able to create an auction\n    POST  /api/v1/auctions -> Auction\n    Headers: JWT\n    Body: {\n         Item,\n         startPrice,\n         endPrice,\n         startingPrice\n    }    \n\n    - users should be able to make a bid\n    POST /api/v1/auctions/{auctionId} -> Bid\n    Headers: JWT\n    Body: {\n        Bid\n    }\n\n\n    - user should be able to view auction details and bid history\n    GET /api/v1/auctions{auctionId} -> Auction & Item\n    Headers: JWT\n\n    GET /api/v1/auctions/{auctionId}/bids?page={}&size={} -> Bid[]\n    Headers: JWT\n\n    \n    \n",
      "fontSize": 24.881376312440214,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "API:\n   - users should be able to create an auction\n    POST  /api/v1/auctions -> Auction\n    Headers: JWT\n    Body: {\n         Item,\n         startPrice,\n         endPrice,\n         startingPrice\n    }    \n\n    - users should be able to make a bid\n    POST /api/v1/auctions/{auctionId} -> Bid\n    Headers: JWT\n    Body: {\n        Bid\n    }\n\n\n    - user should be able to view auction details and bid history\n    GET /api/v1/auctions{auctionId} -> Auction & Item\n    Headers: JWT\n\n    GET /api/v1/auctions/{auctionId}/bids?page={}&size={} -> Bid[]\n    Headers: JWT\n\n    \n    \n",
      "autoResize": true,
      "lineHeight": 1.25
    },
