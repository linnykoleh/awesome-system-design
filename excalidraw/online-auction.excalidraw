    {
      "id": "54YrFiGSfvluMUAravBE1",
      "type": "text",
      "x": 26001.750615160745,
      "y": 1701.9207994182993,
      "width": 858.6473999023438,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#228be6",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
