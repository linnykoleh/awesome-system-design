      "isDeleted": false,
      "boundElements": null,
      "updated": 1780053059103,
      "link": null,
      "locked": false,
      "text": "Functional requirements:\n    - users should be able to create an auction\n    - users should be able to make a bid\n    - user should be able to view auction details and bid history",
      "fontSize": 24.881376312440214,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Functional requirements:\n    - users should be able to create an auction\n    - users should be able to make a bid\n    - user should be able to view auction details and bid history",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "VgKDK4yZ3BCHvJXENSZud",
      "type": "text",
      "x": 23995.438356021652,
      "y": 2117.3959364105403,
      "width": 320.91963935367755,
      "height": 93.3051611716508,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#9775fa",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b6q",
      "roundness": null,
      "seed": 1863827011,
      "version": 346,
      "versionNonce": 1691414285,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1780053059103,
      "link": null,
      "locked": false,
      "text": "Scale:\n    - 10M concurrent auctions\n    - 100M DAU",
      "fontSize": 24.881376312440214,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Scale:\n    - 10M concurrent auctions\n    - 100M DAU",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "7Lse7NzsftNOMv5EPNpP0",
      "type": "text",
      "x": 24007.6168134506,
      "y": 2301.47647639626,
      "width": 691.9750089947315,
      "height": 186.6103223433016,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#9775fa",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b6s",
      "roundness": null,
      "seed": 1378902115,
      "version": 617,
      "versionNonce": 676955501,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1780053059103,
      "link": null,
      "locked": false,
      "text": "Non functional requirements:\n    - strong consistency for bids\n    - fault tolerance on bid placing (can't drop any bids)\n    - real time client updates on bid history\n    - system should be able to handle 10M concurrent auctions\n    - system should be able to handle 100M DAU",
      "fontSize": 24.881376312440214,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Non functional requirements:\n    - strong consistency for bids\n    - fault tolerance on bid placing (can't drop any bids)\n    - real time client updates on bid history\n    - system should be able to handle 10M concurrent auctions\n    - system should be able to handle 100M DAU",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "d5zQ33hX6PVy0_1tdCXV2",
      "type": "text",
      "x": 24010.043141989623,
      "y": 2570.3851320802028,
      "width": 147.17319282081147,
      "height": 155.50860195275132,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#9775fa",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
