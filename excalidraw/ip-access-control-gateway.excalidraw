      "isDeleted": false,
      "boundElements": null,
      "updated": 1779726593488,
      "link": null,
      "locked": false,
      "text": "Non functional requirements:\n    - 1M DAU\n    - sla: 50p - 100ms, 90p - 1s, 99p - 30s\n    - caching fetched IP for 5H",
      "fontSize": 24.031307687946203,
      "fontFamily": 6,
      "textAlign": "left",
