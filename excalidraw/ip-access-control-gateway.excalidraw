    {
      "id": "tKJ1REyaQ9T3ykfScwhbo",
      "type": "text",
      "x": 12424.502482142816,
      "y": -183.0993939384129,
      "width": 919.6172485351562,
      "height": 176.70714024903307,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#eebefa",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dotted",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a1",
      "roundness": null,
      "seed": 1215500954,
      "version": 775,
      "versionNonce": 122457798,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779726741841,
      "link": null,
      "locked": false,
      "text": "Government provide an API to check the IP.\n\nImagine you are working in social media company, company operates in many\ncountries. Some country come out policy and this affect every business to forcing \nto check every IP address and Government provide list of addresses which are banned.\nIf banned - not allow process, if ok - allow.",
      "fontSize": 23.56095203320441,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Government provide an API to check the IP.\n\nImagine you are working in social media company, company operates in many\ncountries. Some country come out policy and this affect every business to forcing \nto check every IP address and Government provide list of addresses which are banned.\nIf banned - not allow process, if ok - allow.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "TqiI-VS8iYsvGMOHF-A8i",
      "type": "text",
      "x": 12513.74498716867,
      "y": 124.52877163436301,
      "width": 546.7115165234663,
      "height": 90.11740382979826,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#eebefa",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dotted",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a2",
      "roundness": null,
      "seed": 1507096326,
      "version": 414,
      "versionNonce": 1995139802,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779726433059,
      "link": null,
      "locked": false,
      "text": "Functional requirements:\n    - check every IP before processing\n    - return correct HTTP code 403 in case of failing",
      "fontSize": 24.031307687946203,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Functional requirements:\n    - check every IP before processing\n    - return correct HTTP code 403 in case of failing",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
