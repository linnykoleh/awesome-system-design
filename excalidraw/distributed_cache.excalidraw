      "roundness": null,
      "seed": 238367514,
      "version": 415,
      "versionNonce": 64930116,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1779785771856,
      "link": null,
      "locked": false,
      "text": "Preparation before hand:\n    - populate cache\n    - populate cache from access log by job\n    - ask for restricted IPs from third-party\n    - collect list of IPs\n",
      "fontSize": 23.35286234395755,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Preparation before hand:\n    - populate cache\n    - populate cache from access log by job\n    - ask for restricted IPs from third-party\n    - collect list of IPs\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "zDOC12LcJXiJfcGvnXJMp",
      "type": "text",
      "x": 13923.527118270342,
      "y": 603.34117418982,
      "width": 442.7603289533983,
      "height": 59.23697819730225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#da77f2",
