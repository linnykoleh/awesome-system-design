      "text": "1M * 100 requests = 100M rps\n10^8 / 10^5 = 10^3 RPS * 100 peek = 10^5 rps at peek",
      "fontSize": 22.010532241858833,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1M * 100 requests = 100M rps\n10^8 / 10^5 = 10^3 RPS * 100 peek = 10^5 rps at peek",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "D4X9dTVJm7qR0SDemXTtI",
