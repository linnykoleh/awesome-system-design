    {
      "id": "9-9u8wqBmUY_nD4pJ6OKA",
      "type": "text",
      "x": 13103.77682160904,
      "y": 475.1358402008392,
      "width": 956.4995575590661,
      "height": 107.70919829672454,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#da77f2",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "al",
      "roundness": null,
      "seed": 648038908,
      "version": 232,
      "versionNonce": 1477803460,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779791910611,
      "link": null,
      "locked": false,
      "text": "Non functional requirements:\n    - system should be highly available. Eventual consistency is acceptable.\n    - system should support low latency operations (< 10ms for get and set requests).\n    - system should be scalable to support the expected 1TB of data and 100k requests per second.",
      "fontSize": 21.54183965934491,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Non functional requirements:\n    - system should be highly available. Eventual consistency is acceptable.\n    - system should support low latency operations (< 10ms for get and set requests).\n    - system should be scalable to support the expected 1TB of data and 100k requests per second.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "uP6wBPuL2L9_JTnb-YGj4",
      "type": "text",
