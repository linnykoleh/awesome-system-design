      "isDeleted": true,
      "boundElements": [],
      "updated": 1779785771856,
      "link": null,
      "locked": false,
      "text": "100 bytes * 100M rps = 10B  = 10G RAM",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "100 bytes * 100M rps = 10B  = 10G RAM",
