    {
      "id": "j_sx_jdAHhYlkXoRRGooj",
      "type": "text",
      "x": 15212.088717602523,
      "y": 342.07887957612655,
      "width": 4.175994873046875,
      "height": 20,
      "angle": 0,
      "strokeColor": "#1e1e1e",
