      "boundElements": [],
      "updated": 1779785771856,
      "link": null,
      "locked": false,
      "text": "- Cache should be replicated\n- Check IP before 5H, async update cache",
      "fontSize": 23.694791278920903,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- Cache should be replicated\n- Check IP before 5H, async update cache",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "UmpKPUV3gY7x6QvplSdiL",
      "type": "text",
      "x": 13099.468453677171,
      "y": 164.93334910627254,
      "width": 739.0995457530571,
      "height": 107.70919829672454,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#da77f2",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ai",
      "roundness": null,
      "seed": 2108413436,
      "version": 244,
      "versionNonce": 1511218884,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779791910611,
      "link": null,
      "locked": false,
      "text": "Functional requirements:\n    - users should be able to set, get, and delete key-value pairs.\n    - users should be able to configure the expiration time for key-value pairs.\n    - data should be evicted according to Least Recently Used (LRU) policy.",
      "fontSize": 21.54183965934491,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Functional requirements:\n    - users should be able to set, get, and delete key-value pairs.\n    - users should be able to configure the expiration time for key-value pairs.\n    - data should be evicted according to Least Recently Used (LRU) policy.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "3bJo6rj3PDppi81e-d3O7",
      "type": "text",
      "x": 13105.249361888154,
      "y": 341.3912627119803,
      "width": 510.7994998196128,
      "height": 80.7818987225434,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#da77f2",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aj",
      "roundness": null,
      "seed": 79739004,
      "version": 206,
      "versionNonce": 289596996,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779791910611,
      "link": null,
      "locked": false,
      "text": "Scale:\n    - need to store up to 1TB of data \n    - handle a peak of up to 100k requests per second",
      "fontSize": 21.54183965934491,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Scale:\n    - need to store up to 1TB of data \n    - handle a peak of up to 100k requests per second",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "MXySRBhvQo2LeDW3S1Unf",
      "type": "text",
      "x": 13324.915625185771,
      "y": 284.6017104495015,
      "width": 5.2199859619140625,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#da77f2",
      "fillStyle": "solid",
