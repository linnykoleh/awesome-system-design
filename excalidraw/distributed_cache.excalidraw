    {
      "id": "owMXK4UJmyrGhRfVsqbfU",
      "type": "text",
      "x": 13937.0727976127,
      "y": -134.58062237095407,
      "width": 440.73089599609375,
      "height": 175.14646757968163,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#da77f2",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
