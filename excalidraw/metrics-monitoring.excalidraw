  "elements": [
    {
      "id": "99f-WVrv8038Xe1dS2nyQ",
      "type": "text",
      "x": 16086.429178364711,
      "y": 51.48405978991377,
      "width": 566.5792236328125,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2V",
      "roundness": null,
      "seed": 1595131311,
      "version": 429,
      "versionNonce": 1152575599,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779954866866,
      "link": null,
      "locked": false,
      "text": "Functional requirements:\n    - ingest metrics (cpu, memory, error)\n    - query and visualize metrics (time ranges, filters)\n    - users are define alert rules/thresholds\n    - user should be able to receive notifications when alerts fire",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Functional requirements:\n    - ingest metrics (cpu, memory, error)\n    - query and visualize metrics (time ranges, filters)\n    - users are define alert rules/thresholds\n    - user should be able to receive notifications when alerts fire",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "s-1S0Q7F0AHkebz6tX-mP",
      "type": "text",
      "x": 16082.916614762815,
      "y": 256.57378817714573,
      "width": 247.61972045898438,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2W",
      "roundness": null,
      "seed": 666168353,
      "version": 199,
      "versionNonce": 526943055,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779954864457,
      "link": null,
      "locked": false,
      "text": "Scale:\n    - 500k servers\n    - 100 metrics\n    - 10s emission frequency\n    - 5M metrics per second",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Scale:\n    - 500k servers\n    - 100 metrics\n    - 10s emission frequency\n    - 5M metrics per second",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "iqXmu8C_5tHX3f9-eg61B",
      "type": "text",
      "x": 16075.550978473986,
      "y": 443.61709357336247,
      "width": 521.039306640625,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2X",
      "roundness": null,
      "seed": 435831183,
      "version": 606,
      "versionNonce": 547172385,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779954862599,
      "link": null,
      "locked": false,
      "text": "Non functional requirements:\n    - avalibility >> consistency, eventual consistency ok\n    - support 5M metrics per second and 500k servers\n    - handle late/out of order data gracefully\n    - low latency on rendering a metrics in dashboard (~2s)\n    - alert latency < 1 minute",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Non functional requirements:\n    - avalibility >> consistency, eventual consistency ok\n    - support 5M metrics per second and 500k servers\n    - handle late/out of order data gracefully\n    - low latency on rendering a metrics in dashboard (~2s)\n    - alert latency < 1 minute",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Zz48SRePYojp1e1rE8vWT",
      "type": "text",
      "x": 16084.43929098849,
      "y": 660.1178392973427,
      "width": 459.8194580078125,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2Z",
      "roundness": null,
      "seed": 850189615,
      "version": 302,
      "versionNonce": 58408353,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779954861049,
      "link": null,
      "locked": false,
      "text": "Core entities:\n    - metric -> CPU\n    - label -> region, service name\n    - series (metrics + labels over time)\n    - alert rule -> if cpu exceeds 90% for 5 minutes\n    - dashboard -> collection of series and metadata",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Core entities:\n    - metric -> CPU\n    - label -> region, service name\n    - series (metrics + labels over time)\n    - alert rule -> if cpu exceeds 90% for 5 minutes\n    - dashboard -> collection of series and metadata",
      "autoResize": true,
      "lineHeight": 1.25
    },
