    {
      "id": "x8N1RSNcFz1j1ns11Yh_k",
      "type": "text",
      "x": 16084.874965466755,
      "y": 890.2176514117102,
      "width": 818.6990356445312,
      "height": 750,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2w",
      "roundness": null,
      "seed": 1590461391,
      "version": 637,
      "versionNonce": 361636271,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779952633572,
      "link": null,
      "locked": false,
      "text": "API:\n    - ingest metrics (cpu, memory, error)\n    POST /api/v1/metrics/inject\n    Headers: JWT\n    body: {\n        metrics: [\n            {\n                name: \"cpu_usage\",\n                labels: [\"west\", \"arm\", \"web\"],\n                value: 0.75\n                timestamp: 146543334\n            }\n        ]\n    }\n\n     - query and visualize metrics (time ranges, filters)\n    GET /api/v1/metrics/query?q=avg(cpu_usage(region=\"west\"))&start=x&end=y -> Metrics \n    Headers: JWT\n\n    - users are define alert rules/thresholds\n    POST /api/v1/alert/rules\n    Headers: JWT\n    body : {\n        name:\n        query: avg(cpu_usage(region=\"west\"))\n        for: 5m\n        notifications: [\"slack\", \"email\"]\n    }\n\n",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "API:\n    - ingest metrics (cpu, memory, error)\n    POST /api/v1/metrics/inject\n    Headers: JWT\n    body: {\n        metrics: [\n            {\n                name: \"cpu_usage\",\n                labels: [\"west\", \"arm\", \"web\"],\n                value: 0.75\n                timestamp: 146543334\n            }\n        ]\n    }\n\n     - query and visualize metrics (time ranges, filters)\n    GET /api/v1/metrics/query?q=avg(cpu_usage(region=\"west\"))&start=x&end=y -> Metrics \n    Headers: JWT\n\n    - users are define alert rules/thresholds\n    POST /api/v1/alert/rules\n    Headers: JWT\n    body : {\n        name:\n        query: avg(cpu_usage(region=\"west\"))\n        for: 5m\n        notifications: [\"slack\", \"email\"]\n    }\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
