  "elements": [
    {
      "id": "wVAUQ10XH7yIO5cNnHVU1",
      "type": "text",
      "x": 14564.793934514844,
      "y": -191.58275875736035,
      "width": 573.3093820531213,
      "height": 98.3986330411223,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b17",
      "roundness": null,
      "seed": 1685530564,
      "version": 558,
      "versionNonce": 965304577,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779880605997,
      "link": null,
      "locked": false,
      "text": "Functional requirements;\n    - merchant should be able to make a payment\n    - users should be able to pay via credit/debit card\n    - merchant should be able to view status updates for payment",
      "fontSize": 19.67972660822446,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Functional requirements;\n    - merchant should be able to make a payment\n    - users should be able to pay via credit/debit card\n    - merchant should be able to view status updates for payment",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "D9zHySB71CjcEqwb0Ean8",
      "type": "text",
      "x": 14562.684706003854,
      "y": 99.85592693640899,
      "width": 346.65804187464516,
      "height": 221.39692434252515,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b18",
      "roundness": null,
      "seed": 1570826564,
      "version": 874,
      "versionNonce": 1855428833,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1779880605997,
      "link": null,
      "locked": false,
      "text": "Non functional requirements:\n    - the system should be highly secure\n    - consistency >> availability\n        - we deal with money\n        - no double charges\n    - strong durability (audibility)\n    - scalable to handle 10k tps\n\n ",
      "fontSize": 19.67972660822446,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Non functional requirements:\n    - the system should be highly secure\n    - consistency >> availability\n        - we deal with money\n        - no double charges\n    - strong durability (audibility)\n    - scalable to handle 10k tps\n\n ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "sL1HMZlQTBCY19XuBEroB",
